# === LiteLLM Agent Engine ===
# Set the model to use (provider/model format).
# Examples:
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
#   gemini/gemini-2.0-flash
#   groq/llama-3.3-70b-versatile
#   ollama/llama3
MODEL=xai/grok-4-latest

# === API Keys (set the ones you need) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# === File access sandboxing ===
# Colon-separated list of directories agents may read from.
# Default (when unset): the project root directory only.
# The expense-receipts workflow reads files from ~/Downloads or ~/Desktop —
# add those paths here if you use that skill.
# ALLOWED_READ_DIRS=/Users/you/Downloads:/Users/you/Desktop

# === Memory compression ===
# When a memory file exceeds MEMORY_MAX_LINES (30), the engine sends it to
# the LLM to deduplicate. Set to false if memory may contain sensitive data
# (credentials, PII) that you don't want transmitted to the provider.
# MEMORY_COMPRESS_ENABLED=true

# Row count threshold that triggers LLM memory compression (default: 30).
# MEMORY_MAX_LINES=30

# Minimum conversation messages before end-of-session memory extraction runs (default: 12).
# MEMORY_MIN_MESSAGES=12

# === Memory write limit ===
# Maximum characters accepted per remember() call (default: 2000).
# MEMORY_WRITE_MAX_CHARS=2000

# === Boatswain sandbox ===
# Directory where The Boatswain writes files and runs shell commands.
# Default (when unset): sandbox/ inside the project root.
# BOATSWAIN_SANDBOX_DIR=/Users/you/boatswain-workspace

# Docker image used for sandboxed execution. Must have 'sh' available.
# Docker is required — run_shell will not fall back to the host environment.
# Change to a language-specific image if your tasks need a specific runtime,
# e.g. node:20-slim, python:3.12-slim, ubuntu:24.04.
# BOATSWAIN_DOCKER_IMAGE=python:3.12-slim

# === HTTP API (serve subcommand) ===
# API_HOST=0.0.0.0
# API_PORT=8420
# API_KEY=
# SESSION_TTL_SECONDS=7200
# MAX_CONCURRENT_SESSIONS=20
